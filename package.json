{
  "name": "askmian-backend",
  "version": "1.0.0",
  "description": "Ask Mian API server - Hono + tRPC + Drizzle ORM + MySQL",
  "type": "module",
  "scripts": {
    "build": "esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "prestart": "npx drizzle-kit push",
    "start": "NODE_ENV=production node dist/boot.js",
    "dev": "tsx api/boot.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@tanstack/react-query": "^5.74.4",
    "@trpc/client": "^11.1.1",
    "@trpc/react-query": "^11.1.1",
    "@trpc/server": "^11.1.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.42.0",
    "esbuild": "^0.25.3",
    "hono": "^4.7.7",
    "mysql2": "^3.14.1",
    "stripe": "^18.0.0",
    "superjson": "^2.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.0"
  }
}
