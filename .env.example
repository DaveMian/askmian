# Ask Mian — Environment Variables

# Database (from Railway MySQL)
DATABASE_URL=mysql://root:password@host:port/database

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key

# Admin Dashboard Password
ADMIN_PASSWORD=your_secure_admin_password_here

# App credentials (auto-generated by Kimi)
APP_ID=your_app_id
APP_SECRET=your_app_secret
VITE_APP_ID=your_app_id

# Environment
NODE_ENV=production
