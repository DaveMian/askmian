# Backend Environment Variables
# Add these in Railway dashboard (Variables tab)

# Database (from Railway MySQL service)
DATABASE_URL=mysql://root:password@mysql.railway.internal:3306/railway

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_secret_key
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key

# Admin Dashboard Password (choose a strong one)
ADMIN_PASSWORD=your_secure_admin_password

# Environment
NODE_ENV=production

# App credentials (from Kimi portal)
APP_ID=your_app_id
APP_SECRET=your_app_secret
