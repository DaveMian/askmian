# Ask Mian Website — Environment Variables

# Database (auto-provided by Railway MySQL or use the existing one)
DATABASE_URL=mysql://user:password@host:port/database

# Stripe (required for card payments)
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key

# Admin Dashboard Password
# Set a strong password. If not set, defaults to "admin123"
ADMIN_PASSWORD=your_secure_admin_password_here

# App credentials (auto-generated)
APP_ID=your_app_id
APP_SECRET=your_app_secret
VITE_APP_ID=your_app_id
